# Copy to .env and fill in.

# LLM provider (openai | anthropic | openai-compat)
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
LLM_API_KEY=
# Only set when LLM_PROVIDER=openai-compat (OpenRouter, Groq, Together, Azure, local vLLM, ...)
LLM_BASE_URL=

# SQLite path. On Railway, point this at the mounted volume.
DB_PATH=./data/vendors.db

LOG_LEVEL=INFO
